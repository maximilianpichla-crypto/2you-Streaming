{
  "name": "2you-streaming",
  "version": "1.0.0",
  "description": "2you Streaming – desktop streaming app for Twitch and more",
  "main": "dist-electron/main.js",
  "author": "2you Streaming",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/free-port.js 5173 && node scripts/patch-vite-electron.js",
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder",
    "push-update": "node scripts/push-update.cjs",
    "fetch-ffmpeg": "node scripts/fetch-ffmpeg.js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/tmi.js": "^1.8.6",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.2you.streaming",
    "productName": "2you Streaming",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "updates",
        "to": "updates",
        "filter": [
          "feed.json"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "allowScripts": {
    "electron@36.9.5": true,
    "esbuild@0.25.12": true
  }
}
