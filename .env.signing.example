# Code-Signing für Windows (Authenticode)
#
# 1. Zertifikat kaufen (OV Code Signing), z. B.:
#    - SSL.com, Sectigo, DigiCert
#    - oder Azure Trusted Signing (Cloud)
# 2. Als .pfx exportieren nach: certs/codesign.pfx
# 3. Diese Datei nach .env.signing kopieren und Passwort setzen:
#
#    copy .env.signing.example .env.signing
#
WIN_CSC_LINK=certs/codesign.pfx
WIN_CSC_KEY_PASSWORD=
